# ============================================================
# GastosAI — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real a git
# ============================================================

# --- Proveedor LLM ---
# Opciones: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# --- Anthropic Claude (si LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- OpenAI (si LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...

# --- Ollama local (si LLM_PROVIDER=ollama) ---
# Ollama debe correr en el host antes de levantar Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# --- Configuración general ---
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173
